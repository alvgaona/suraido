---
import Slide from "suraido/components/Slide.astro";
---

<Slide title="Typography">
  <div class="deck-eyebrow" style="margin-bottom: 24px">Type</div>
  <h1 class="deck-title">A serif that speaks, a sans that works.</h1>
  <div style="margin-top: 48px; display: grid; gap: 32px">
    <div style="border-bottom: 1px solid var(--deck-line); padding-bottom: 24px">
      <div class="deck-mono" style="font-size: 18px; color: var(--deck-faint)">Display · Fraunces · 60–120px</div>
      <div class="deck-serif" style="font-size: 72px; line-height: 1.05">Headlines carry the voice.</div>
    </div>
    <div style="border-bottom: 1px solid var(--deck-line); padding-bottom: 24px">
      <div class="deck-mono" style="font-size: 18px; color: var(--deck-faint)">Body · Inter · 20–34px</div>
      <p style="font-size: 30px; color: var(--deck-muted); margin: 0">
        Body copy stays quiet so the headline doesn't have to compete.
      </p>
    </div>
    <div>
      <div class="deck-mono" style="font-size: 18px; color: var(--deck-faint)">Mono · JetBrains Mono · labels</div>
      <div class="deck-mono" style="font-size: 26px">SKU-0042 · 2026-Q1 · v1.0</div>
    </div>
  </div>
</Slide>
