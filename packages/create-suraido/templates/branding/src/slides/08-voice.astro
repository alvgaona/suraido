---
import Slide from "suraido/components/Slide.astro";
import Columns from "suraido/components/Columns.astro";
import Callout from "suraido/components/Callout.astro";
---

<Slide title="Voice">
  <div class="deck-eyebrow" style="margin-bottom: 24px">Tone</div>
  <h1 class="deck-title">Say it like you'd say it out loud.</h1>
  <div style="margin-top: 48px">
    <Columns cols={2} gap={40}>
      <Callout variant="success">
        <Fragment slot="mark">✓</Fragment>
        <div style="font-size: 22px; color: var(--deck-faint); margin-bottom: 10px">We write</div>
        "Your invoice is ready. Pay it in two clicks."
      </Callout>
      <Callout variant="danger">
        <Fragment slot="mark">✕</Fragment>
        <div style="font-size: 22px; color: var(--deck-faint); margin-bottom: 10px">We don't write</div>
        "We are pleased to inform you that your invoicing documentation has been generated."
      </Callout>
    </Columns>
  </div>
</Slide>
