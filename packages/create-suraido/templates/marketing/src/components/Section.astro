---
// Divider: an oversized accent numeral, then the title.
import Slide from "suraido/components/Slide.astro";
interface Props { label?: string; title: string; note?: string; number?: boolean }
const { label, title, note, number = false } = Astro.props;
---

<Slide title={title} number={number}>
  <div class="section">
    {label && <div class="section__num">{label}</div>}
    <h1 class="section__title">{title}</h1>
    {note && <p class="section__note">{note}</p>}
  </div>
</Slide>
