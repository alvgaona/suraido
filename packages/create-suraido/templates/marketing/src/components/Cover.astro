---
// Campaign cover: a solid accent bar, a pill eyebrow, then a heavy sans title.
import Slide from "suraido/components/Slide.astro";
interface Props { eyebrow?: string; title?: string; lead?: string; number?: boolean }
const { eyebrow, title, lead, number = false } = Astro.props;
---

<Slide title={title ?? eyebrow ?? "Cover"} number={number}>
  <div class="cover">
    <div class="cover__bar"></div>
    {eyebrow && <div class="cover__pill">{eyebrow}</div>}
    <slot name="title"><h1 class="cover__title">{title}</h1></slot>
    {lead && <p class="cover__lead">{lead}</p>}
    <div class="cover__actions"><slot /></div>
  </div>
</Slide>
