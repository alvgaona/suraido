---
import Slide from "suraido/components/Slide.astro";
import Timeline from "suraido/components/Timeline.astro";
import Event from "suraido/components/Event.astro";
---

<Slide title="Timeline">
  <div class="deck-eyebrow" style="margin-bottom: 24px">When</div>
  <h1 class="deck-title">Eight weeks, four beats.</h1>
  <div style="margin-top: 48px">
    <Timeline>
      <Event date="Weeks 1–2" title="Tease">Creative in production, waitlist opens.</Event>
      <Event date="Week 3" title="Launch day">Landing page, press, founder post, paid live.</Event>
      <Event date="Weeks 4–6" title="Sustain">Customer stories weekly, iterate on the top ad.</Event>
      <Event date="Weeks 7–8" title="Read out">Full-funnel report and the keep/kill call.</Event>
    </Timeline>
  </div>
</Slide>
