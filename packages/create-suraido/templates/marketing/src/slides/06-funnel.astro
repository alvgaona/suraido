---
import Slide from "suraido/components/Slide.astro";
import Steps from "suraido/components/Steps.astro";
import Step from "suraido/components/Step.astro";
---

<Slide title="Funnel">
  <div class="deck-eyebrow" style="margin-bottom: 24px">Journey</div>
  <h1 class="deck-title">From scroll to signup.</h1>
  <div style="margin-top: 48px; font-size: 30px">
    <Steps>
      <Step><strong>See</strong> — a 12-second product clip in the feed.</Step>
      <Step><strong>Read</strong> — landing page with one story and one button.</Step>
      <Step><strong>Try</strong> — free workspace, no card, first invoice in minutes.</Step>
      <Step><strong>Stay</strong> — day-3 email with the metric they just saved.</Step>
    </Steps>
  </div>
</Slide>
