---
import Slide from "suraido/components/Slide.astro";
import Table from "suraido/components/Table.astro";
---

<Slide title="Channels">
  <div class="deck-eyebrow" style="margin-bottom: 24px">Where</div>
  <h1 class="deck-title">Four channels, one budget.</h1>
  <div style="margin-top: 48px">
    <Table>
      <thead>
        <tr><th>Channel</th><th>Budget</th><th>Owner</th><th>Primary metric</th></tr>
      </thead>
      <tbody>
        <tr><td>Paid social</td><td>$40k</td><td>Growth</td><td>Cost per trial</td></tr>
        <tr><td>Lifecycle email</td><td>$6k</td><td>Lifecycle</td><td>Trial → paid</td></tr>
        <tr><td>Content / SEO</td><td>$18k</td><td>Content</td><td>Organic signups</td></tr>
        <tr><td>Partners</td><td>$12k</td><td>BD</td><td>Referred teams</td></tr>
      </tbody>
    </Table>
  </div>
</Slide>
