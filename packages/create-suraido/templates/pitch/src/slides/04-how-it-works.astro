---
import Slide from "suraido/components/Slide.astro";
import Steps from "suraido/components/Steps.astro";
import Step from "suraido/components/Step.astro";
---

<Slide title="How it works" notes="One arrow-press per step — let each land before the next.">
  <div class="deck-eyebrow" style="margin-bottom: 24px">Product</div>
  <h1 class="deck-title">Three steps, zero spreadsheets.</h1>
  <div style="margin-top: 48px; font-size: 30px">
    <Steps>
      <Step><strong>Connect</strong> — pull hours from the tools the team already uses.</Step>
      <Step><strong>Review</strong> — we draft the invoice; a human approves it in one click.</Step>
      <Step><strong>Collect</strong> — automatic reminders until the money lands.</Step>
    </Steps>
  </div>
</Slide>
