---
import Slide from "suraido/components/Slide.astro";
import Table from "suraido/components/Table.astro";
---

<Slide title="Business model">
  <div class="deck-eyebrow" style="margin-bottom: 24px">Model</div>
  <h1 class="deck-title">Per seat, plus a slice of what we collect.</h1>
  <div style="margin-top: 48px">
    <Table>
      <thead>
        <tr><th>Plan</th><th>Price</th><th>Who it's for</th></tr>
      </thead>
      <tbody>
        <tr><td>Starter</td><td>$29 / seat / mo</td><td>Under 10 seats</td></tr>
        <tr><td>Team</td><td>$24 / seat / mo</td><td>10–100 seats</td></tr>
        <tr><td>Scale</td><td>Custom + 0.4% collected</td><td>100+ seats</td></tr>
      </tbody>
    </Table>
    <p style="margin-top: 36px; font-size: 26px; color: var(--deck-muted)">
      CAC $780 · payback 4.1 months · net revenue retention 118%.
    </p>
  </div>
</Slide>
