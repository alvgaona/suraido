---
import Slide from "suraido/components/Slide.astro";
import Table from "suraido/components/Table.astro";
---

<Slide title="Competition" notes="Own the weakness — the honest column is what earns trust.">
  <div class="deck-eyebrow" style="margin-bottom: 24px">Landscape</div>
  <h1 class="deck-title">Everyone bills. Nobody automates it end to end.</h1>
  <div style="margin-top: 48px">
    <Table>
      <thead>
        <tr><th></th><th>Spreadsheets</th><th>Legacy suites</th><th>Acme</th></tr>
      </thead>
      <tbody>
        <tr><td>Setup time</td><td>Minutes</td><td>Weeks</td><td>Minutes</td></tr>
        <tr><td>Pulls hours automatically</td><td>No</td><td>Partial</td><td>Yes</td></tr>
        <tr><td>Chases payment</td><td>No</td><td>No</td><td>Yes</td></tr>
        <tr><td>Price</td><td>Free</td><td>$$$</td><td>$$</td></tr>
      </tbody>
    </Table>
  </div>
</Slide>
