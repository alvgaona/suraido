{
  "name": "suraido",
  "version": "0.1.0",
  "description": "suraido — an Astro slide framework: single-page runtime, component library, portals, presenter, PDF export",
  "keywords": [
    "slides",
    "presentation",
    "astro",
    "deck",
    "slideshow",
    "keynote"
  ],
  "license": "MIT",
  "author": "Alvaro Gaona (@alvgaona)",
  "homepage": "https://github.com/alvgaona/suraido",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvgaona/suraido.git"
  },
  "bugs": "https://github.com/alvgaona/suraido/issues",
  "type": "module",
  "exports": {
    ".": "./integration.ts",
    "./DeckLayout.astro": "./DeckLayout.astro",
    "./Deck.astro": "./Deck.astro",
    "./Presenter.astro": "./Presenter.astro",
    "./slides": "./slides.ts",
    "./react": "./react/index.ts",
    "./styles.css": "./styles/global.css",
    "./components/*": "./components/*"
  },
  "files": [
    "components",
    "styles",
    "themes",
    "react",
    "*.astro",
    "*.ts"
  ],
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@fontsource-variable/fraunces": "^5.3.0",
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource-variable/geist-mono": "^5.3.0",
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource-variable/jetbrains-mono": "^5.1.0",
    "@fontsource/geist-pixel": "^5.3.0",
    "@radix-ui/react-scroll-area": "^1",
    "@tailwindcss/vite": "^4.1.0",
    "cmdk": "^1.1.1",
    "katex": "^0.16.11",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.1.0"
  },
  "peerDependencies": {
    "astro": "^7.0.0",
    "mermaid": ">=10",
    "recharts": ">=2"
  },
  "peerDependenciesMeta": {
    "mermaid": {
      "optional": true
    },
    "recharts": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "mermaid": "^11.0.0",
    "recharts": "^3.0.0"
  }
}
