---
import Slide from "./Slide.astro";
interface Props {
  eyebrow?: string;
  title?: string;
  lead?: string;
  number?: boolean;
}
const { eyebrow, title, lead, number = false } = Astro.props;
---

<Slide title={title ?? eyebrow ?? "Cover"} number={number}>
  <div class="deck-cover">
    {eyebrow && <div class="deck-eyebrow" style="margin-bottom: 28px">{eyebrow}</div>}
    <slot name="title"><h1 class="deck-title" style="font-size: 120px">{title}</h1></slot>
    {lead && <p class="deck-lead" style="margin-top: 36px; font-size: 34px">{lead}</p>}
    <div class="deck-cover__actions"><slot /></div>
  </div>
</Slide>
