---
import Slide from "./Slide.astro";
interface Props {
  label?: string;
  title: string;
  note?: string;
  number?: boolean;
}
const { label, title, note, number = false } = Astro.props;
---

<Slide title={title} number={number}>
  <div class="deck-section">
    {label && <div class="deck-section__label">{label}</div>}
    <div class="deck-eyebrow">Section</div>
    <h1 class="deck-section__title">{title}</h1>
    {note && <p class="deck-lead" style="margin-top: 32px; font-size: 32px">{note}</p>}
  </div>
</Slide>
