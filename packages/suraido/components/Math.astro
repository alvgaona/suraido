---
import katex from "katex";
import { math as enabled } from "virtual:suraido/options";
interface Props {
  expr: string;
  display?: boolean;
}
const { expr, display = false } = Astro.props;
// The katex stylesheet is loaded globally by the integration when math is on.
const html = enabled ? katex.renderToString(expr, { displayMode: display, throwOnError: false }) : "";
---

{enabled ? <span set:html={html} /> : <code class="deck-kbd">{expr}</code>}
