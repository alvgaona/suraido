---
interface Props {
  /**
   * The Mermaid definition. Omit it to write the diagram as children instead —
   * in that case add `is:raw` (`<Mermaid is:raw>`) so Astro doesn't parse `{}`
   * as expressions, which flowchart diamonds and class diagrams rely on.
   */
  chart?: string;
  /** Optional caption under the diagram. */
  caption?: string;
}
const { chart, caption } = Astro.props;

// Slot children arrive HTML-escaped; bring them back to plain text.
const decode = (s: string) =>
  s
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&quot;/g, '"')
    .replace(/&#(?:39|x27);/g, "'")
    .replace(/&amp;/g, "&");

/** Strip the shared indentation the definition picked up from the template. */
function dedent(text: string): string {
  const lines = text.replace(/\t/g, "  ").split("\n");
  const indents = lines.filter((l) => l.trim()).map((l) => l.match(/^ */)![0].length);
  const shift = indents.length ? Math.min(...indents) : 0;
  return lines.map((l) => l.slice(shift)).join("\n").trim();
}

const definition = chart ?? dedent(decode(await Astro.slots.render("default")));
---

<figure class="deck-mermaid">
  <div class="deck-mermaid__graph" data-mermaid={definition}></div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<script>
  // Mermaid is an optional peer: this script (and the library) is only bundled
  // when a deck actually uses <Mermaid>, same as the Recharts islands.
  import mermaid from "mermaid";

  const graphs = () => document.querySelectorAll<HTMLElement>("[data-mermaid]");

  /** Map the deck's --deck-* contract onto Mermaid's theme variables. */
  function themeVariables() {
    const cs = getComputedStyle(document.documentElement);
    const v = (name: string) => cs.getPropertyValue(name).trim();
    return {
      background: v("--deck-bg"),
      primaryColor: v("--deck-panel-2"),
      primaryTextColor: v("--deck-fg"),
      primaryBorderColor: v("--deck-accent"),
      secondaryColor: v("--deck-panel"),
      tertiaryColor: v("--deck-panel"),
      lineColor: v("--deck-line-strong"),
      textColor: v("--deck-fg"),
      mainBkg: v("--deck-panel-2"),
      nodeBorder: v("--deck-accent"),
      clusterBkg: v("--deck-panel"),
      clusterBorder: v("--deck-line"),
      titleColor: v("--deck-fg"),
      edgeLabelBackground: v("--deck-bg"),
      fontFamily: v("--deck-font") || "sans-serif",
      fontSize: "26px",
    };
  }

  let pass = 0;
  async function renderAll() {
    const nodes = [...graphs()];
    if (nodes.length === 0) return;
    mermaid.initialize({
      startOnLoad: false,
      securityLevel: "loose",
      theme: "base",
      themeVariables: themeVariables(),
    });
    pass += 1;
    await Promise.all(
      nodes.map(async (el, i) => {
        const definition = el.dataset.mermaid;
        if (!definition) return;
        try {
          // Mermaid needs a fresh id per render (re-renders on theme change).
          const { svg } = await mermaid.render(`deck-mermaid-${pass}-${i}`, definition);
          el.innerHTML = svg;
        } catch (err) {
          console.error("suraido: Mermaid failed to render a diagram", err);
        }
      }),
    );
    document.documentElement.dataset.mermaidReady = "1";
    // Diagrams change slide heights — let the deck runtime re-fit around them.
    window.dispatchEvent(new Event("resize"));
  }

  void renderAll();

  // Follow the deck's dark/light toggle: re-render with the new palette.
  new MutationObserver(() => void renderAll()).observe(document.documentElement, {
    attributeFilter: ["data-theme"],
  });
</script>
