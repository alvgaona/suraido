---
interface Props {
  /** Render a numbered <ol> instead of a bulleted <ul>. */
  ordered?: boolean;
  /** Reveal items one at a time as you advance through the slide. */
  reveal?: boolean;
}
const { ordered = false, reveal = false } = Astro.props;
const Tag = ordered ? "ol" : "ul";
---

<Tag class:list={["deck-list", reveal && "deck-list--reveal"]}><slot /></Tag>
