---
interface Props {
  ordered?: boolean;
  /** Reveal items one at a time (requires `items`; wraps each as a fragment). */
  reveal?: boolean;
  /** Items as HTML strings. Omit to write <li> children yourself via the slot. */
  items?: string[];
}
const { ordered = false, reveal = false, items } = Astro.props;
const Tag = ordered ? "ol" : "ul";
---

<Tag class="deck-list">
  {
    items ? (
      items.map((it) => <li class:list={[reveal && "deck-fragment"]} set:html={it} />)
    ) : (
      <slot />
    )
  }
</Tag>
