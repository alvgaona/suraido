---
// A dependency-free bar chart rendered to inline SVG at build time.
interface Props {
  data: { label: string; value: number }[];
  /** Force the top of the scale (defaults to the max value). */
  max?: number;
  /** Suffix on value labels, e.g. "%". */
  unit?: string;
  /** SVG viewbox height. */
  height?: number;
}
const { data, max, unit = "", height = 380 } = Astro.props;

const W = 1000;
const PAD_BOTTOM = 52;
const PAD_TOP = 44;
const maxV = max ?? Math.max(...data.map((d) => d.value), 1);
const n = Math.max(data.length, 1);
const gap = 28;
const barW = (W - gap * (n - 1)) / n;
const plot = height - PAD_BOTTOM - PAD_TOP;
---

<svg viewBox={`0 0 ${W} ${height}`} class="deck-chart" preserveAspectRatio="xMidYMid meet" role="img">
  {
    data.map((d, i) => {
      const h = Math.max((d.value / maxV) * plot, 2);
      const x = i * (barW + gap);
      const y = height - PAD_BOTTOM - h;
      return (
        <g>
          <rect x={x} y={y} width={barW} height={h} rx="10" fill="var(--deck-accent)" />
          <text x={x + barW / 2} y={y - 14} text-anchor="middle" class="deck-chart__val">
            {d.value}
            {unit}
          </text>
          <text x={x + barW / 2} y={height - 16} text-anchor="middle" class="deck-chart__lbl">
            {d.label}
          </text>
        </g>
      );
    })
  }
</svg>
