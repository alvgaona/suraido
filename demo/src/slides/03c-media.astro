---
import Slide from "suraido/components/Slide.astro";
import Columns from "suraido/components/Columns.astro";
import Grid from "suraido/components/Grid.astro";
import Image from "suraido/components/Image.astro";
import Video from "suraido/components/Video.astro";
import Badge from "suraido/components/Badge.astro";
import Card from "suraido/components/Card.astro";
---

<Slide title="Media & grid">
  <div class="deck-eyebrow" style="margin-bottom: 24px">Media</div>
  <h1 class="deck-title">Images, video, grids.</h1>
  <div style="margin-top: 44px">
    <Columns cols={2} gap={48}>
      <Image src="https://picsum.photos/1200/700" alt="Sample" caption="<Image> — inline, with caption" />
      <Video
        src="https://storage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4"
        muted
        loop
        controls
        caption="<Video> — a themed <video> wrapper"
      />
    </Columns>
    <div style="margin-top: 40px">
      <Grid cols={4} gap={20}>
        <Card><Badge>Grid</Badge></Card>
        <Card><Badge>N-up</Badge></Card>
        <Card><Badge>logos</Badge></Card>
        <Card><Badge>features</Badge></Card>
      </Grid>
    </div>
  </div>
</Slide>
