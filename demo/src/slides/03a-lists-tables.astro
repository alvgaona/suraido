---
import Slide from "suraido/components/Slide.astro";
import Columns from "suraido/components/Columns.astro";
import List from "suraido/components/List.astro";
import ListItem from "suraido/components/ListItem.astro";
import Table from "suraido/components/Table.astro";
---

<Slide title="Lists & tables">
  <div class="deck-eyebrow" style="margin-bottom: 24px">Content</div>
  <h1 class="deck-title">Lists and tables.</h1>
  <div style="margin-top: 48px">
    <Columns cols={2} gap={64}>
      <List>
        <ListItem>A styled list with accent markers</ListItem>
        <ListItem>Items can hold <code class="deck-kbd">inline</code> markup</ListItem>
        <ListItem>Pass <code class="deck-kbd">reveal</code> to step through them</ListItem>
      </List>
      <Table>
        <thead><tr><th>Component</th><th>Kind</th></tr></thead>
        <tbody>
          <tr><td>List</td><td>content</td></tr>
          <tr><td>Table</td><td>content</td></tr>
          <tr><td>Chart</td><td>data</td></tr>
          <tr><td>Timeline</td><td>data</td></tr>
        </tbody>
      </Table>
    </Columns>
  </div>
</Slide>
