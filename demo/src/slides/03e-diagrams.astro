---
import Slide from "suraido/components/Slide.astro";
import Columns from "suraido/components/Columns.astro";
import Mermaid from "suraido/components/Mermaid.astro";
import List from "suraido/components/List.astro";

const flow = `flowchart LR
  A[".astro slides"] --> B["Astro build"]
  B --> C["one HTML page"]
  C --> D["client runtime"]
  D --> E["present"]
  D --> F["PDF export"]`;
---

<Slide title="Diagrams">
  <div class="deck-eyebrow" style="margin-bottom: 24px">Diagrams</div>
  <h1 class="deck-title">Mermaid, themed.</h1>
  <div style="margin-top: 44px">
    <Columns cols={2} gap={64} align="center">
      <Mermaid chart={flow} caption="flowchart — renders on the client, follows the theme" />
      <List
        items={[
          "Write <code class='deck-kbd'>flowchart</code>, <code class='deck-kbd'>sequenceDiagram</code>, and the rest",
          "Colors come from the <code class='deck-kbd'>--deck-*</code> palette",
          "Re-renders when you flip dark / light",
        ]}
      />
    </Columns>
  </div>
</Slide>
