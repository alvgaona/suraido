---
import Slide from "suraido/components/Slide.astro";
import Columns from "suraido/components/Columns.astro";
import Mermaid from "suraido/components/Mermaid.astro";
import List from "suraido/components/List.astro";
import ListItem from "suraido/components/ListItem.astro";
import pipeline from "../diagrams/pipeline.mmd?raw";
---

<Slide title="Diagrams">
  <div class="deck-eyebrow" style="margin-bottom: 24px">Diagrams</div>
  <h1 class="deck-title">Mermaid, themed.</h1>
  <div style="margin-top: 44px">
    <Columns cols={2} gap={64} align="center">
      <Mermaid chart={pipeline} caption="kept in its own .mmd file" />
      <List reveal>
        <ListItem>Diagrams live in <code class="deck-kbd">.mmd</code> files — real editor tooling</ListItem>
        <ListItem>Colors come from the <code class="deck-kbd">--deck-*</code> palette</ListItem>
        <ListItem>Re-renders when you flip dark / light</ListItem>
      </List>
    </Columns>
  </div>
</Slide>
